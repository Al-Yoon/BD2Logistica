# MongoDB Atlas (o compatible): cadena "Connect your application"
# Si la contraseña tiene caracteres especiales, codifícala en la URI (URL encode).
# Si falla TLS con "alert internal error" (p. ej. en Windows), prueba: MONGODB_DNS_FAMILY=4
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.ejemplo.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=logistica

# Neo4j Aura (o instancia gestionada): URI que te da el panel (suele ser neo4j+s://...)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_contraseña_instancia
